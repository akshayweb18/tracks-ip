{
  "extends": ["next/core-web-vitals", "prettier"],
  "rules": {
    "react/no-unescaped-entities": "warn",
    "react/display-name": "off",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "@next/next/no-img-element": "warn"
  },
  "env": {
    "node": true,
    "browser": true,
    "es2021": true
  }
}
