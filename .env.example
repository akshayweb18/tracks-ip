# MongoDB Connection URI
# Local development example:
# MONGODB_URI=mongodb://localhost:27017/tracks-ip

# MongoDB Atlas (cloud) example:
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/tracks-ip?retryWrites=true&w=majority

# Next.js public API URL (for client-side requests)
NEXT_PUBLIC_API_URL=http://localhost:3000

# === Heartbeat Agent Configuration ===
# These are OPTIONAL - the agent auto-detects system data if not provided

# Override auto-detected employee name (defaults to Windows username)
# EMPLOYEE_NAME=John Doe

# Override API endpoint for heartbeat (defaults to http://localhost:3000/api/heartbeat)
# API_URL=http://localhost:3000/api/heartbeat

# Optional: Node environment
NODE_ENV=development
