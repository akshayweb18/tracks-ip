{
  "name": "tracking-system",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "vercel-build": "pnpm install --no-frozen-lockfile && next build",
    "dev": "concurrently \"next dev --webpack\" \"node heartbeat.js\"",
    "build": "next build",
    "start": "next start",
    "heartbeat": "node heartbeat.js",
    "cleanup": "node scripts/cleanupDuplicates.js",
    "cleanup:ip": "node scripts/cleanupByIP.js",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\""
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-icons": "^1.3.2",
    "@shadcn/ui": "^0.0.4",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.3.1",
    "lucide-react": "^0.575.0",
    "mongodb": "^7.1.0",
    "mongoose": "^9.2.3",
    "next": "16.1.6",
    "node-fetch": "^3.3.2",
    "os": "^0.1.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0",
    "systeminformation": "^5.31.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "postcss": "^8.5.6",
    "prettier": "^3.1.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  }
}
