{
  "buildCommand": "pnpm run build",
  "devCommand": "pnpm run dev",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": "nextjs",
  "env": {
    "MONGODB_URI": {
      "description": "MongoDB connection URI"
    }
  },
  "regions": ["iad1"],
  "functions": {
    "src/app/api/**": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}